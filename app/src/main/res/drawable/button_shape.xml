<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">

        <shape android:shape="rectangle">
            <gradient android:angle="135" android:endColor="@color/purple_300" android:startColor="@color/purple_400" />
            <corners android:radius="8dp" />
        </shape>

    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="225" android:endColor="@color/purple_200" android:startColor="@color/purple_300" />
            <corners android:radius="8dp" />
        </shape>

    </item>
</selector>